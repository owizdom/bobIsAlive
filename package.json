{
  "name": "digital-organism",
  "version": "1.0.0",
  "description": "An autonomous AI agent inside an EigenCompute TEE that must earn credits to pay for its own compute. If its balance hits zero, it dies.",
  "main": "dist/agents/orchestrator.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "start": "node dist/agents/orchestrator.js",
    "dev": "tsx agents/orchestrator.ts",
    "supervise": "bash scripts/supervise-swarm.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "openai": "^4.73.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
