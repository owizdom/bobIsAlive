# ── LLM Provider — pick one: anthropic, openai, eigenai ──────────
LLM_PROVIDER=grok
LLM_PROVIDER_ORDER=eigenai,openai,anthropic,grok,groq,local

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# EigenAI
# EIGENAI_API_KEY=your_key
# EIGENAI_API_URL=https://api.eigenai.xyz/v1
# EIGENAI_MODEL=gpt-oss-120b-f16

# Grok (console.grok / xAI)
GROK_API_KEY=your_grok_key
GROK_API_URL=https://api.x.ai/v1
GROK_MODEL=grok-beta

# Local LLM fallback (owned infra)
LOCAL_LLM_API_URL=http://127.0.0.1:8000/v1
# LOCAL_LLM_API_KEY=optional
# LOCAL_LLM_MODEL=local-infra-model

# LLM failover policy
LLM_FAILOVER_FAILURES=3
LLM_FAILOVER_COOLDOWN_MS=30000

# ── Swarm Config ─────────────────────────────────────────────────
SYNC_INTERVAL_MS=2000
PHEROMONE_DECAY=0.12
CRITICAL_DENSITY=0.55
TOKEN_BUDGET_PER_AGENT=50000

# ── Commit-Reveal ─────────────────────────────────────────────────
EXPLORE_STEPS=12            # blind analysis steps before commit (12 × 2s = 24s)

# ── Oracle ────────────────────────────────────────────────────────
DASHBOARD_PORT=3001

# ── EigenCompute TEE (set automatically when running in enclave) ──
# EIGENCOMPUTE_INSTANCE_ID=ec-...

# ── Autonomous Control (self-management + crash recovery) ───────────
AUTONOMY_ENABLED=true
AUTONOMY_STATE_FILE=swarm-orchestrator-state.json
AUTONOMY_HEARTBEAT_MS=10000
AUTONOMY_STALE_RECOVERY_MS=90000
AUTONOMY_MAX_STEP_FAILURES=6
AGENT_STEP_TIMEOUT_MS=20000
DEGRADE_RECOVERY_PAUSE_MS=15000
LOOP_STALL_WARN_STEPS=3
PHASE_TIMEOUT_MARGIN_STEPS=4

# Supervisor restart policy (used by npm run supervise)
MAX_RESTARTS=30
RESTART_DELAY_SEC=5
BACKOFF_SEC=2
